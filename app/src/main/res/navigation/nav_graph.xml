<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_view"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.maxler.roaa.ui.fragment.HomeFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_searchFragment"
            app:destination="@id/searchFragment" />
        <action
            android:id="@+id/action_homeFragment_to_mostPlayedFragment"
            app:destination="@id/mostPlayedFragment" />
        <action
            android:id="@+id/action_homeFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
        <action
            android:id="@+id/action_homeFragment_to_lastAddFragment"
            app:destination="@id/lastAddFragment" />
    </fragment>
    <fragment
        android:id="@+id/albumsFragment"
        android:name="com.maxler.roaa.ui.fragment.AlbumsFragment"
        android:label="fragment_albums"
        tools:layout="@layout/fragment_albums" />
    <fragment
        android:id="@+id/playlistsFragment"
        android:name="com.maxler.roaa.ui.fragment.PlaylistsFragment"
        android:label="fragment_playlists"
        tools:layout="@layout/fragment_playlists" />
    <fragment
        android:id="@+id/artistsFragment"
        android:name="com.maxler.roaa.ui.fragment.ArtistsFragment"
        android:label="fragment_artists"
        tools:layout="@layout/fragment_artists" />
    <fragment
        android:id="@+id/songsFragment"
        android:name="com.maxler.roaa.ui.fragment.SongsFragment"
        android:label="fragment_songs"
        tools:layout="@layout/fragment_songs" />
    <fragment
        android:id="@+id/historyFragment"
        android:name="com.maxler.roaa.ui.fragment.HistoryFragment"
        android:label="fragment_history"
        tools:layout="@layout/fragment_history" />
    <fragment
        android:id="@+id/lastAddFragment"
        android:name="com.maxler.roaa.ui.fragment.LastAddFragment"
        android:label="fragment_last_add"
        tools:layout="@layout/fragment_last_add" />
    <fragment
        android:id="@+id/mostPlayedFragment"
        android:name="com.maxler.roaa.ui.fragment.MostPlayedFragment"
        android:label="fragment_most_played"
        tools:layout="@layout/fragment_most_played" />
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.maxler.roaa.ui.fragment.SearchFragment"
        android:label="fragment_search"
        tools:layout="@layout/fragment_search" />
    <fragment
        android:id="@+id/videoListFragment"
        android:name="com.maxler.roaa.ui.fragment.VideoListFragment"
        android:label="fragment_video_list"
        tools:layout="@layout/fragment_video_list" />
    <fragment
        android:id="@+id/settingFragment"
        android:name="com.maxler.roaa.ui.fragment.SettingFragment"
        android:label="fragment_setting"
        tools:layout="@layout/fragment_setting" />
</navigation>